# The dev server is pinned to port 5173 in package.json (not Next's default
# 3000). The backend's CORS is locked to a single origin via FRONTEND_URL, and
# its .env sets that to http://localhost:5173 — as do the SSL_*_FRONTEND_URL
# payment redirects and the Google OAuth callback. Serving on any other port
# makes every API call fail CORS with an opaque "Failed to fetch".

# Bare origin of the Express server — used for OAuth full-page redirects.
NEXT_PUBLIC_API_ORIGIN=http://localhost:5000

# All modules are mounted under /api/v1 (see backend src/app.ts).
NEXT_PUBLIC_API_BASE_URL=http://localhost:5000/api/v1

NEXT_PUBLIC_SITE_NAME=TourLink
